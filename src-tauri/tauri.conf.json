{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scan2BIM Converter",
  "version": "0.1.0",
  "identifier": "com.scan2bim.converter",
  "build": {
    "frontendDist": "../renderer",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Scan2BIM Converter",
        "width": 540,
        "height": 540,
        "minWidth": 480,
        "minHeight": 480,
        "maxWidth": 720,
        "maxHeight": 720,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#15151a",
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Graphics",
    "shortDescription": "E57 to Potree converter",
    "longDescription": "Scan2BIM Converter turns E57 point clouds into Potree v2 octrees for the Scan2BIM web viewer.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
